# Database (PostgreSQL)
DATABASE_URL=postgres://user:password@localhost:5432/sentinel_delivery

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=123456789:ABC-DEF...

# API Server
PORT=3100
HOST=0.0.0.0

# Security
# Shared secret with Sentinel for webhook signature verification
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=your-32-char-minimum-secret-here
# Optional separate admin key for internal/status endpoints
# ADMIN_KEY=your-admin-key

# Base URL for account linking page (`/link` gets appended by the bot)
# Update these for production deployments.
LINK_BASE_URL=http://localhost:3100
# Base URL for account linking page
# LINK_BASE_URL=https://sentinel.monarchlend.xyz/telegram


# Base URL for the user-facing Sentinel app
APP_BASE_URL=https://sentinel.monarchlend.xyz

# Optional
LOG_LEVEL=info
NODE_ENV=development
