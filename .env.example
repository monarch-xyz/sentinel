# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sentinel

# API
API_PORT=3000
API_HOST=0.0.0.0
# Optional launch gate for /api/v1/auth/register
# If set, clients must send X-Admin-Key with this exact value.
# REGISTER_ADMIN_KEY=replace-with-strong-random-secret
# Browser/session auth
SESSION_COOKIE_NAME=sentinel_session
SESSION_TTL_HOURS=720
NONCE_TTL_MINUTES=10
AUTH_SIWE_DOMAIN=localhost:3000
AUTH_SIWE_URI=http://localhost:3000

# Worker
WORKER_INTERVAL_SECONDS=30

# Envio Indexer
# Optional. If unset, indexed semantic DSL refs stay disabled and the API rejects them.
ENVIO_ENDPOINT=https://indexer.bigdevenergy.link/your-endpoint/v1/graphql
# Validate event filter fields via schema introspection (default: true outside tests)
# ENVIO_VALIDATE_SCHEMA=true

# HyperSync
# Optional. If unset, raw-events stay disabled and the API rejects them.
# Required for live raw-event / HyperSync queries and live HyperSync integration tests
# ENVIO_API_TOKEN=your-envio-api-token
# Optional per-chain override. Defaults to https://{chainId}.hypersync.xyz
# HYPERSYNC_URL_1=https://1.hypersync.xyz

# Webhooks
WEBHOOK_TIMEOUT_MS=10000
WEBHOOK_MAX_RETRIES=3
# WEBHOOK_SECRET=your-signing-secret

# Optional internal Delivery integration for /api/v1/me/integrations/*
DELIVERY_BASE_URL=http://localhost:3100
# DELIVERY_ADMIN_KEY=shared-admin-or-webhook-secret
DELIVERY_TIMEOUT_MS=5000

# Simulation limits
MAX_SIMULATION_STEPS=2000
SIMULATE_RATE_LIMIT=60

# Live integration test toggles
# RUN_LIVE_SNAPSHOT_TESTS=true
# RUN_LIVE_RPC_INTEGRATION_TESTS=true
# RUN_LIVE_HYPERSYNC_TESTS=true

# Logging
LOG_LEVEL=info

# RPC URLs (optional - falls back to public RPCs if not set)
# For production, use your own Alchemy/Infura/QuickNode endpoints
# Multiple URLs can be comma-separated for fallback

# ========== Supported Chains ==========

# Ethereum Mainnet (chainId: 1)
# RPC_URL_1=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Base (chainId: 8453)
# RPC_URL_8453=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Polygon (chainId: 137)
# RPC_URL_137=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# Arbitrum (chainId: 42161)
# RPC_URL_42161=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY

# Monad (chainId: 10143) - Update chainId if different on mainnet
# RPC_URL_10143=https://rpc.monad.xyz

# Unichain (chainId: 130)
# RPC_URL_130=https://rpc.unichain.org

# Hyperliquid (chainId: 999) - Update chainId if different
# RPC_URL_999=https://rpc.hyperliquid.xyz
