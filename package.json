{
  "name": "sentinel",
  "version": "0.1.0",
  "description": "Flexible Signal Monitoring Service for Monarch",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently \"pnpm api\" \"pnpm worker\"",
    "dev:all": "concurrently \"pnpm api\" \"pnpm worker\" \"pnpm delivery:dev\"",
    "docker:up": "./scripts/docker-local.sh",
    "docker:up:all": "./scripts/docker-local.sh --with-delivery",
    "docker:down": "./scripts/docker-local.sh down",
    "docker:reset": "./scripts/docker-local.sh reset",
    "docker:logs": "./scripts/docker-local.sh logs",
    "docker:logs:all": "./scripts/docker-local.sh logs --with-delivery",
    "api": "tsx watch src/api/index.ts",
    "worker": "tsx watch src/worker/index.ts",
    "build": "tsc && pnpm -F @sentinel/delivery build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check --write src tests scripts && pnpm -F @sentinel/delivery lint",
    "lint:check": "biome check src tests scripts && pnpm -F @sentinel/delivery lint:check",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit && pnpm -F @sentinel/delivery typecheck",
    "test:integration": "vitest run tests/integration/",
    "test:integration:fixed": "RUN_LIVE_SNAPSHOT_TESTS=true vitest run tests/integration/fixed-snapshot*.integration.test.ts",
    "test:integration:rpc": "RUN_LIVE_RPC_INTEGRATION_TESTS=true vitest run tests/integration/blocks.integration.test.ts",
    "test:integration:hypersync": "RUN_LIVE_HYPERSYNC_TESTS=true vitest run tests/integration/hypersync.integration.test.ts",
    "test:condition": "tsx src/scripts/test-condition.ts",
    "test:live:envio-rpc": "tsx src/scripts/validate-live-envio-rpc.ts",
    "db:migrate": "tsx src/scripts/migrate.ts",
    "db:migrate:prod": "node dist/scripts/migrate.js",
    "db:reset": "docker exec -i sentinel-postgres psql -U postgres -d sentinel -c 'DROP SCHEMA public CASCADE; CREATE SCHEMA public;' && pnpm db:migrate",
    "delivery:db:migrate": "pnpm -F @sentinel/delivery db:migrate",
    "delivery:db:reset": "docker exec -i sentinel-postgres psql -U postgres -c 'DROP DATABASE IF EXISTS sentinel_delivery;' && docker exec -i sentinel-postgres psql -U postgres -c 'CREATE DATABASE sentinel_delivery;' && pnpm delivery:db:migrate",
    "delivery:dev": "pnpm -F @sentinel/delivery dev",
    "delivery:build": "pnpm -F @sentinel/delivery build"
  },
  "dependencies": {
    "@envio-dev/hypersync-client": "^1.1.0",
    "@types/node-cron": "^3.0.11",
    "axios": "^1.6.2",
    "bullmq": "^5.0.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "graphql": "^16.8.1",
    "graphql-request": "^6.1.0",
    "ioredis": "^5.3.2",
    "node-cron": "^3.0.3",
    "pg": "^8.11.3",
    "pino": "^8.21.0",
    "uuid": "^9.0.1",
    "viem": "^2.45.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.4.1",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "concurrently": "^8.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.9.3",
    "vitest": "^1.1.3"
  },
  "packageManager": "pnpm@10.23.0+sha1.b4a44ab0dc2adf2e36371d11d8eb0dc78ffc976c"
}
