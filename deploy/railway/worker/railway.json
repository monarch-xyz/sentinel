{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "watchPatterns": [
      "/Dockerfile",
      "/package.json",
      "/pnpm-lock.yaml",
      "/tsconfig.json",
      "/src/**",
      "/scripts/**",
      "/deploy/railway/worker/**"
    ]
  },
  "deploy": {
    "startCommand": "node dist/worker/index.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
